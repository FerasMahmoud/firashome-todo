default_platform(:ios)

platform :ios do
  desc "Build, sign, upload to TestFlight"
  lane :beta do
    api_key = app_store_connect_api_key(
      key_id: ENV.fetch("ASC_KEY_ID"),
      issuer_id: ENV.fetch("ASC_ISSUER_ID"),
      key_content: ENV.fetch("ASC_KEY"),
      in_house: false,
      duration: 1200
    )

    # Ensure App Store Connect app record exists (bundle ID already on Developer portal via match)
    begin
      Spaceship::ConnectAPI.token = Spaceship::ConnectAPI::Token.create(
        key_id: ENV.fetch("ASC_KEY_ID"),
        issuer_id: ENV.fetch("ASC_ISSUER_ID"),
        key: ENV.fetch("ASC_KEY")
      )
      app = Spaceship::ConnectAPI::App.find("uk.firashome.todo")
      if app.nil?
        UI.message("Creating App Store Connect app uk.firashome.todo …")
        Spaceship::ConnectAPI::App.create(
          name: "Tasks",
          version_string: "1.0",
          sku: "firashome-todo",
          primary_locale: "en-US",
          bundle_id: "uk.firashome.todo",
          platforms: ["IOS"]
        )
      else
        UI.success("App Store Connect app already exists: #{app.name}")
      end
    rescue => e
      UI.important("App ensure step: #{e.message} — continuing; pilot may still work if app exists")
    end

    match(
      type: "appstore",
      app_identifier: ["uk.firashome.todo"],
      readonly: true,
      api_key: api_key
    )

    update_code_signing_settings(
      use_automatic_signing: false,
      path: "Todo.xcodeproj",
      team_id: "3V4NW789C6",
      code_sign_identity: "iPhone Distribution",
      profile_name: "match AppStore uk.firashome.todo",
      bundle_identifier: "uk.firashome.todo",
      targets: ["Todo"]
    )

    gym(
      scheme: "Todo",
      project: "Todo.xcodeproj",
      export_method: "app-store",
      clean: true,
      include_bitcode: false,
      export_options: {
        method: "app-store",
        signingStyle: "manual",
        teamID: "3V4NW789C6",
        provisioningProfiles: {
          "uk.firashome.todo" => "match AppStore uk.firashome.todo"
        }
      },
      xcargs: [
        "CODE_SIGN_STYLE=Manual",
        'CODE_SIGN_IDENTITY="iPhone Distribution"',
        'PROVISIONING_PROFILE_SPECIFIER="match AppStore uk.firashome.todo"',
        "DEVELOPMENT_TEAM=3V4NW789C6"
      ].join(" ")
    )

    pilot(
      api_key: api_key,
      app_identifier: "uk.firashome.todo",
      skip_waiting_for_build_processing: true,
      skip_submission: true
    )
  end
end
