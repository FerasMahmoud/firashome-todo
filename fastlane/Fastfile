default_platform(:ios)

lane :beta do
  api_key = app_store_connect_api_key(
    key_id: ENV["ASC_KEY_ID"],
    issuer_id: ENV["ASC_ISSUER_ID"],
    key: ENV["ASC_KEY"],          # PEM content passed directly (no file dependency)
    in_house: false,
    duration: 1_200
  )

  begin
    produce(api_key: api_key, app_identifier: "uk.firashome.todo",
            app_name: "Tasks", skip_screenshots: true, skip_metadata: true)
  rescue => e
    UI.important("produce skipped (likely exists): #{e.message}")
  end

  pilot(api_key: api_key, app_identifier: "uk.firashome.todo",
        skip_waiting_for_build_processing: true, skip_submission: true)
end
