default_platform(:ios)

platform :ios do
  desc "Build, sign, upload to TestFlight"
  lane :beta do
    api_key = app_store_connect_api_key(
      key_id: ENV.fetch("ASC_KEY_ID"),
      issuer_id: ENV.fetch("ASC_ISSUER_ID"),
      key_content: ENV.fetch("ASC_KEY"),
      in_house: false,
      duration: 1200
    )

    match(
      type: "appstore",
      app_identifier: ["uk.firashome.todo"],
      readonly: true,
      api_key: api_key
    )

    update_code_signing_settings(
      use_automatic_signing: false,
      path: "Todo.xcodeproj",
      team_id: "3V4NW789C6",
      code_sign_identity: "iPhone Distribution",
      profile_name: "match AppStore uk.firashome.todo",
      bundle_identifier: "uk.firashome.todo",
      targets: ["Todo"]
    )

    gym(
      scheme: "Todo",
      project: "Todo.xcodeproj",
      export_method: "app-store",
      clean: true,
      include_bitcode: false,
      export_options: {
        method: "app-store",
        signingStyle: "manual",
        teamID: "3V4NW789C6",
        provisioningProfiles: {
          "uk.firashome.todo" => "match AppStore uk.firashome.todo"
        }
      },
      xcargs: [
        "CODE_SIGN_STYLE=Manual",
        'CODE_SIGN_IDENTITY="iPhone Distribution"',
        'PROVISIONING_PROFILE_SPECIFIER="match AppStore uk.firashome.todo"',
        "DEVELOPMENT_TEAM=3V4NW789C6"
      ].join(" ")
    )

    # Hard wall if no ASC app record: API key role cannot CREATE apps (GET/UPDATE only).
    # Once "Tasks" (uk.firashome.todo) exists in App Store Connect, pilot succeeds.
    begin
      Spaceship::ConnectAPI.token = Spaceship::ConnectAPI::Token.create(
        key_id: ENV.fetch("ASC_KEY_ID"),
        issuer_id: ENV.fetch("ASC_ISSUER_ID"),
        key: ENV.fetch("ASC_KEY")
      )
      apps = Spaceship::ConnectAPI::App.all
      UI.message("ASC apps visible to API key: #{apps.map { |a| a.bundle_id }.inspect}")
      if apps.none? { |a| a.bundle_id == "uk.firashome.todo" }
        UI.user_error!(<<~MSG)
          IPA built OK, but App Store Connect has ZERO apps for this API key.
          Bundle ID uk.firashome.todo exists on Developer portal; ASC app record does not.
          API key cannot CREATE apps (role is not Admin/Account Holder).
          One-time fix (60s): App Store Connect → My Apps → + → bundle uk.firashome.todo → name Tasks
          Then re-run this workflow. No new secrets needed.
        MSG
      end
    rescue FastlaneCore::Interface::FastlaneError
      raise
    rescue => e
      UI.important("App preflight: #{e.message}")
    end

    pilot(
      api_key: api_key,
      app_identifier: "uk.firashome.todo",
      skip_waiting_for_build_processing: true,
      skip_submission: true
    )
  end
end
