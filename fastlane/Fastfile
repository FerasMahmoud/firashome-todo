default_platform(:ios)

platform :ios do
  desc "Build, sign, upload to TestFlight"
  lane :beta do
    api_key = app_store_connect_api_key(
      key_id: ENV.fetch("ASC_KEY_ID"),
      issuer_id: ENV.fetch("ASC_ISSUER_ID"),
      key_content: ENV.fetch("ASC_KEY"),
      in_house: false,
      duration: 1200
    )

    # Pull App Store cert + profile from match repo (readonly on CI)
    match(
      type: "appstore",
      app_identifier: ["uk.firashome.todo"],
      readonly: true,
      api_key: api_key
    )

    # Wire manual signing into the generated xcodeproj (match alone is not enough)
    update_code_signing_settings(
      use_automatic_signing: false,
      path: "Todo.xcodeproj",
      team_id: "3V4NW789C6",
      code_sign_identity: "iPhone Distribution",
      profile_name: "match AppStore uk.firashome.todo",
      bundle_identifier: "uk.firashome.todo",
      targets: ["Todo"]
    )

    gym(
      scheme: "Todo",
      project: "Todo.xcodeproj",
      export_method: "app-store",
      clean: true,
      include_bitcode: false,
      export_options: {
        method: "app-store",
        signingStyle: "manual",
        teamID: "3V4NW789C6",
        provisioningProfiles: {
          "uk.firashome.todo" => "match AppStore uk.firashome.todo"
        }
      },
      xcargs: [
        "CODE_SIGN_STYLE=Manual",
        'CODE_SIGN_IDENTITY="iPhone Distribution"',
        'PROVISIONING_PROFILE_SPECIFIER="match AppStore uk.firashome.todo"',
        "DEVELOPMENT_TEAM=3V4NW789C6"
      ].join(" ")
    )

    pilot(
      api_key: api_key,
      app_identifier: "uk.firashome.todo",
      skip_waiting_for_build_processing: true,
      skip_submission: true
    )
  end
end
